.post-line{overflow:hidden;white-space:nowrap;text-overflow:ellipsis}.post__title{font-size:2.4rem;font-weight:700;line-height:1.2;margin-bottom:.6em;text-align:left}.post__meta{display:flex;flex-wrap:wrap;align-items:center;gap:8px;margin-bottom:10px;font-size:14px}.post__meta .post__meta-icon{font-size:13px;color:#999}.post__meta .post__meta-text{color:#666}.post__meta-category a{background-color:#e0e0e0;color:#333;padding:0 6px;border-radius:3px;text-decoration:none;line-height:1.6;display:inline-block}.post__meta-tag a{color:#004030;text-decoration:none;font-size:14px;gap:5px;display:inline-block}@media(max-width:768px){.post__header{display:flex;flex-direction:column;align-items:flex-start;margin-bottom:15px!important}.post__header .post__title{order:1;font-size:1.8rem!important;margin:5px 0 10px!important}.post__header .post__meta{order:2;gap:5px;font-size:12px;margin:0!important}.post__header .post__thumbnail-wrapper{order:3;width:100%;margin-top:10px!important;margin-bottom:0!important}.post__header .post__thumbnail-wrapper img{width:100%;height:auto;max-height:250px;object-fit:cover;border-radius:8px}.wrapper__sidebar{padding:10px 0!important;margin:0!important;min-height:auto}.wrapper__sidebar .sidebar__list li{margin-bottom:.5em}body.home .wrapper__main .post{margin-bottom:25px!important;padding-bottom:15px!important;border-bottom:1px dashed #eee}body.home .wrapper__main .post .post__thumbnail-wrapper{margin-top:0!important;margin-bottom:8px!important;max-height:160px;border-radius:8px;overflow:hidden}body.home .wrapper__main .post .post__thumbnail-wrapper img.post__thumbnail{width:100%;height:160px;object-fit:cover;display:block}body.home .wrapper__main .post .post__title{font-size:1.3rem!important;font-weight:700;margin-top:5px!important;margin-bottom:5px!important;line-height:1.3!important}body.home .wrapper__main .post .post__content{margin-top:0!important}body.home .wrapper__main .post .post__content p,body.home .wrapper__main .post .post__content .post-line{margin:0 0 8px!important;font-size:13px!important;line-height:1.5!important;color:#666;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;white-space:normal}body.home .wrapper__main .post .post__footer{margin-top:0!important;padding:0!important;display:flex;flex-wrap:wrap;gap:6px}body.home .wrapper__main .post .post__footer a.category{font-size:11px!important;padding:1px 5px!important;background-color:#f0f0f0;color:#666;border-radius:4px}body.home .wrapper__main .post .post__footer a.tag{font-size:11px!important;color:#999;padding:0}}